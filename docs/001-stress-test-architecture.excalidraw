    {
      "id": "k6-phases",
      "type": "text",
      "x": 805,
      "y": 152,
      "width": 168,
      "height": 320,
      "text": "Phase A: Pre-test\n• Truncate DB tables\n• Flush Redis cache\n• Verify mock health\n\nPhase B: Execute\n• sustained (10 b/s)\n• burst (100 b/s)\n• reorg injection\n• multi-chain\n• endurance (1hr)\n\nPhase C: Post-test\n• Wait pipeline drain\n  (poll DB for last block)\n• Verify chain continuity\n• Verify no gaps\n• Verify all published\n• Verify reorgs correct",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "autoResize": true,
      "version": 1,
      "versionNonce": 42,
      "index": "e1",
      "isDeleted": false,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "backgroundColor": "transparent",
      "seed": 141,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1740000000000,
      "link": null,
      "locked": false,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Phase A: Pre-test\n• Truncate DB tables\n• Flush Redis cache\n• Verify mock health\n\nPhase B: Execute\n• sustained (10 b/s)\n• burst (100 b/s)\n• reorg injection\n• multi-chain\n• endurance (1hr)\n\nPhase C: Post-test\n• Wait pipeline drain\n  (poll DB for last block)\n• Verify chain continuity\n• Verify no gaps\n• Verify all published\n• Verify reorgs correct",
      "lineHeight": 1.5
    },
