{
  "$defs": {
    "AllocationType": {
      "description": "STL ``allocation_type`` classification emitted in the exported contract.\n\nA closed set of the values the legacy allocation tracker used; the enum\nvalues are exactly those strings so the export remains byte-for-byte\ncompatible.",
      "enum": [
        "allocation",
        "pol",
        "asset",
        "psm3",
        "risk_capital"
      ],
      "title": "AllocationType",
      "type": "string"
    },
    "AlmProxiesContainer": {
      "additionalProperties": false,
      "properties": {
        "AlmProxy": {
          "additionalProperties": {
            "additionalProperties": {
              "items": {
                "$ref": "#/$defs/ProxyEntry"
              },
              "type": "array"
            },
            "type": "object"
          },
          "title": "Almproxy",
          "type": "object"
        }
      },
      "required": [
        "AlmProxy"
      ],
      "title": "AlmProxiesContainer",
      "type": "object"
    },
    "AscModel": {
      "additionalProperties": false,
      "properties": {
        "entities": {
          "$ref": "#/$defs/EntitiesModel"
        }
      },
      "required": [
        "entities"
      ],
      "title": "AscModel",
      "type": "object"
    },
    "AssetsByPrimeContainer": {
      "additionalProperties": false,
      "properties": {
        "ASSETS_BY_PRIME": {
          "additionalProperties": {
            "items": {
              "$ref": "#/$defs/TokenEntryModel"
            },
            "type": "array"
          },
          "title": "Assets By Prime",
          "type": "object"
        }
      },
      "required": [
        "ASSETS_BY_PRIME"
      ],
      "title": "AssetsByPrimeContainer",
      "type": "object"
    },
    "AxisSynomeModel": {
      "additionalProperties": false,
      "properties": {
        "spec": {
          "$ref": "#/$defs/SpecModel"
        }
      },
      "required": [
        "spec"
      ],
      "title": "AxisSynomeModel",
      "type": "object"
    },
    "EntitiesModel": {
      "additionalProperties": false,
      "properties": {
        "assets_by_prime": {
          "$ref": "#/$defs/AssetsByPrimeContainer"
        },
        "alm_proxies": {
          "$ref": "#/$defs/AlmProxiesContainer"
        }
      },
      "required": [
        "assets_by_prime",
        "alm_proxies"
      ],
      "title": "EntitiesModel",
      "type": "object"
    },
    "ProxyEntry": {
      "additionalProperties": false,
      "description": "A single ALM-controlled wallet exported for a (star, chain).\n\nMore than one may exist per (star, chain): the canonical ALM Proxy plus any\nadditional SubProxy/treasury wallets. ``role`` lets consumers tell them apart\nwithout relying on list position.",
      "properties": {
        "star": {
          "title": "Star",
          "type": "string"
        },
        "chain": {
          "title": "Chain",
          "type": "string"
        },
        "address": {
          "title": "Address",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "star",
        "chain",
        "address",
        "role"
      ],
      "title": "ProxyEntry",
      "type": "object"
    },
    "SpecModel": {
      "additionalProperties": false,
      "properties": {
        "asc": {
          "$ref": "#/$defs/AscModel"
        }
      },
      "required": [
        "asc"
      ],
      "title": "SpecModel",
      "type": "object"
    },
    "TokenEntryModel": {
      "additionalProperties": false,
      "properties": {
        "contract_address": {
          "title": "Contract Address",
          "type": "string"
        },
        "wallet_address": {
          "title": "Wallet Address",
          "type": "string"
        },
        "asset_address": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Asset Address"
        },
        "star": {
          "title": "Star",
          "type": "string"
        },
        "chain": {
          "title": "Chain",
          "type": "string"
        },
        "protocol": {
          "title": "Protocol",
          "type": "string"
        },
        "allocation_type": {
          "$ref": "#/$defs/AllocationType"
        },
        "token_type": {
          "$ref": "#/$defs/TokenType"
        }
      },
      "required": [
        "contract_address",
        "wallet_address",
        "asset_address",
        "star",
        "chain",
        "protocol",
        "allocation_type",
        "token_type"
      ],
      "title": "TokenEntryModel",
      "type": "object"
    },
    "TokenType": {
      "description": "STL ``token_type`` classification emitted in the exported contract.\n\nA closed set of the values the legacy allocation tracker used; the enum\nvalues are exactly those strings so the export remains byte-for-byte\ncompatible.",
      "enum": [
        "atoken",
        "erc4626",
        "erc20",
        "curve",
        "uni_v3_pool",
        "uni_v3_lp",
        "centrifuge",
        "centrifuge_feeder",
        "anchorage",
        "superstate",
        "psm3",
        "proxy"
      ],
      "title": "TokenType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "version": {
      "title": "Version",
      "type": "string"
    },
    "axis_synome_git_commit": {
      "title": "Axis Synome Git Commit",
      "type": "string"
    },
    "axis_synome": {
      "$ref": "#/$defs/AxisSynomeModel"
    }
  },
  "required": [
    "version",
    "axis_synome_git_commit",
    "axis_synome"
  ],
  "title": "AxisSynomeContract",
  "type": "object"
}
