{
  "name": "@stl-verify/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#env": "./env.ts",
    "#src/*": "./src/*",
    "#styled-system/*": "./styled-system/*"
  },
  "scripts": {
    "codegen:styles": "panda codegen",
    "prepare": "npm run codegen:styles",
    "predev": "npm run codegen:styles",
    "dev": "vite",
    "prebuild": "npm run codegen:styles",
    "build": "vite build",
    "pretype:check": "npm run codegen:styles",
    "type:check": "tsgo -b",
    "format": "uikit-cli format --write \"src/**/*.ts\" \"src/**/*.tsx\" panda.config.ts vite.config.ts",
    "format:check": "uikit-cli format --check \"src/**/*.ts\" \"src/**/*.tsx\" panda.config.ts vite.config.ts",
    "preview": "vite preview",
    "generate:openapi-types": "openapi-typescript ./src/generated/openapi-schema.json --output ./src/generated/openapi-types.ts",
    "prelint": "npm run codegen:styles",
    "lint": "uikit-cli lint src panda.config.ts vite.config.ts"
  },
  "dependencies": {
    "@archon-research/http-client-react": "0.2.2-dev25318411334",
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "viem": "^2.23.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@archon-research/design-system": "0.2.2-dev25318411334",
    "@archon-research/oxfmt-config": "0.2.2-dev25318411334",
    "@archon-research/oxlint-config": "0.2.2-dev25318411334",
    "@archon-research/tsconfig": "0.2.2-dev25318411334",
    "@pandacss/dev": "^1.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260504.1",
    "@vitejs/plugin-react": "^4.3.0",
    "openapi-typescript": "^7.6.1",
    "postcss": "^8.5.6",
    "vite": "^5.2.0"
  }
}
