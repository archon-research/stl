{
  "name": "@stl-verify/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#env": "./env.ts",
    "#src/*": "./src/*",
    "#styled-system/*": "./styled-system/*"
  },
  "scripts": {
    "prepare": "panda codegen",
    "dev": "vite",
    "build": "vite build",
    "type:check": "tsgo -b",
    "format": "uikit-cli format --write \"src/**/*.ts\" \"src/**/*.tsx\" panda.config.ts vite.config.ts",
    "format:check": "uikit-cli format --check \"src/**/*.ts\" \"src/**/*.tsx\" panda.config.ts vite.config.ts",
    "preview": "vite preview",
    "test:explorers": "node scripts/check-explorer-urls.mjs",
    "generate:openapi-types": "openapi-typescript ./src/generated/openapi-schema.json --output ./src/generated/openapi-types.ts",
    "lint": "uikit-cli lint src panda.config.ts vite.config.ts"
  },
  "dependencies": {
    "@archon-research/http-client-core": "0.5.0",
    "@archon-research/http-client-react": "0.5.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-table": "8.21.3",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "viem": "2.52.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@archon-research/design-system": "0.5.0",
    "@archon-research/oxfmt-config": "0.5.0",
    "@archon-research/oxlint-config": "0.5.0",
    "@archon-research/tsconfig": "0.5.0",
    "@pandacss/dev": "1.11.1",
    "@types/node": "24.13.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260601.1",
    "@vitejs/plugin-react": "6.0.2",
    "openapi-typescript": "7.13.0",
    "postcss": "8.5.15",
    "vite": "8.0.16"
  },
  "optionalDependencies": {
    "@typescript/native-preview-darwin-arm64": "7.0.0-dev.20260601.1",
    "@typescript/native-preview-linux-x64": "7.0.0-dev.20260601.1",
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
