{
  "name": "@stl-verify/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "oxfmt -c ./.oxfmtrc.ts --write \"src/**/*.ts\" \"src/**/*.tsx\" vite.config.ts",
    "format:check": "oxfmt -c ./.oxfmtrc.ts --check \"src/**/*.ts\" \"src/**/*.tsx\" vite.config.ts",
    "preview": "vite preview",
    "generate:openapi-types": "openapi-typescript ./src/generated/openapi-schema.json --output ./src/generated/openapi-types.ts",
    "lint": "oxlint -c ./.oxlintrc.ts src vite.config.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@archon-research/oxfmt-config": "0.0.0",
    "@archon-research/oxlint-config": "0.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "openapi-typescript": "^7.6.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
