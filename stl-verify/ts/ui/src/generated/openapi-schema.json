            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Allocations"
      }
    },
    "/v1/primes/{prime_id}/capital-metrics": {
      "get": {
        "description": "Retrieve capital metrics for a prime.\n\nResponds with:\n- risk_capital: Total risk-bearing capital\n- capital_buffer: Baseline protective capital\n- first_loss_capital: Prime-owned first-loss layer\n- total_capital: Sum of capital tiers\n- risk_to_capital_ratio: Risk / Capital (use for alert thresholds, e.g., >1.0)\n- is_validated: Whether reconciled against external benchmark\n- validation_note: Any caveats or pending work on this endpoint",
        "operationId": "get_capital_metrics_v1_primes__prime_id__capital_metrics_get",
        "parameters": [
          {
            "in": "path",
            "name": "prime_id",
            "required": true,
            "schema": {
              "title": "Prime Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/CapitalMetricsResponse"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Response Get Capital Metrics V1 Primes  Prime Id  Capital Metrics Get"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
