  "info": {
    "title": "stl-verify",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/allocations/activity": {
      "get": {
        "description": "Retrieve allocation activity events with optional URL filters.\n\nQuery parameters:\n- prime_id: Filter by prime address (0x-prefixed Ethereum address)\n- chain_id: Filter by chain ID\n- protocol_name: Filter by protocol name (case-insensitive substring)\n- action_type: Filter by action type (`in`, `out`, `sweep`)\n- token_symbol: Filter by token symbol (case-insensitive substring)\n- tx_hash: Filter by transaction hash (0x-prefixed)\n- from_timestamp: Inclusive lower timestamp bound (ISO-8601)\n- to_timestamp: Inclusive upper timestamp bound (ISO-8601)\n- limit: Max results (default 100, max 1000)",
        "operationId": "list_allocation_activity_v1_allocations_activity_get",
        "parameters": [
          {
            "in": "query",
            "name": "prime_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Prime Id"
            }
          },
          {
            "in": "query",
            "name": "chain_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Chain Id"
            }
          },
          {
            "in": "query",
            "name": "protocol_name",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Protocol Name"
            }
          },
          {
            "in": "query",
            "name": "action_type",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Action Type"
            }
          },
          {
            "in": "query",
            "name": "token_symbol",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Token Symbol"
            }
          },
          {
            "in": "query",
            "name": "tx_hash",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Tx Hash"
            }
          },
          {
            "in": "query",
            "name": "from_timestamp",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "format": "date-time",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "From Timestamp"
            }
          },
          {
            "in": "query",
            "name": "to_timestamp",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "format": "date-time",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "To Timestamp"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AllocationActivityResponse"
                  },
                  "title": "Response List Allocation Activity V1 Allocations Activity Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Allocation Activity"
      }
    },
