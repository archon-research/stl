  "info": {
    "title": "stl-verify",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/ready": {
      "get": {
        "operationId": "get_ready_v1_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Ready"
      }
    },
    "/v1/risk/{receipt_token_id}/bad-debt": {
      "get": {
        "description": "Estimate bad debt for a receipt token position at the given collateral price gap.",
        "operationId": "get_bad_debt_v1_risk__receipt_token_id__bad_debt_get",
        "parameters": [
          {
            "in": "path",
            "name": "receipt_token_id",
            "required": true,
            "schema": {
              "title": "Receipt Token Id",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "gap_pct",
            "required": true,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                  "type": "string"
                }
              ],
              "title": "Gap Pct"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadDebtResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Bad Debt"
      }
    },
    "/v1/risk/{receipt_token_id}/breakdown": {
      "get": {
        "description": "Return the full risk-enriched collateral breakdown for a receipt token position.",
        "operationId": "get_risk_breakdown_v1_risk__receipt_token_id__breakdown_get",
        "parameters": [
          {
            "in": "path",
            "name": "receipt_token_id",
            "required": true,
            "schema": {
              "title": "Receipt Token Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RiskBreakdownResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Risk Breakdown"
      }
    },
    "/v1/stars": {
      "get": {
        "operationId": "list_stars_v1_stars_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/StarResponse"
                  },
                  "title": "Response List Stars V1 Stars Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Stars"
      }
    },
    "/v1/stars/{star_id}/allocations": {
      "get": {
        "operationId": "list_allocations_v1_stars__star_id__allocations_get",
        "parameters": [
          {
            "in": "path",
            "name": "star_id",
            "required": true,
            "schema": {
              "title": "Star Id",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "block_number",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Block Number"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AllocationPositionResponse"
                  },
                  "title": "Response List Allocations V1 Stars  Star Id  Allocations Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Allocations"
      }
    },
    "/v1/stars/{star_id}/receipt-tokens": {
      "get": {
        "operationId": "list_receipt_tokens_v1_stars__star_id__receipt_tokens_get",
        "parameters": [
          {
            "in": "path",
            "name": "star_id",
            "required": true,
            "schema": {
              "title": "Star Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ReceiptTokenPositionResponse"
                  },
                  "title": "Response List Receipt Tokens V1 Stars  Star Id  Receipt Tokens Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Receipt Tokens"
      }
    },
    "/v1/status": {
      "get": {
        "operationId": "get_status_v1_status_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Status"
      }
    }
  }
}
