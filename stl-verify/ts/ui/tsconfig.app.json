{
  "extends": "@archon-research/tsconfig/react",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],
    "preserveSymlinks": true,
    "paths": {
      "#src/*": ["./src/*"],
      "#styled-system/*": ["./styled-system/*"]
    }
  },
  "include": ["src", "styled-system"]
}
