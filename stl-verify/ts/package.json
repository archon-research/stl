{
  "name": "@stl-verify/workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace=@stl-verify/ui",
    "format": "npm run format --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present",
    "generate:openapi": "make -C ../python export-openapi-schema && npm run generate:openapi-types --workspace=@stl-verify/ui",
    "lint": "npm run lint --workspaces --if-present",
    "type:check": "npm run type:check --workspaces --if-present",
    "uikit:link": "uikit-cli link",
    "uikit:unlink": "uikit-cli unlink"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tanstack/react-table": "^8.20.0"
  },
  "devDependencies": {
    "@archon-research/uikit-cli": "0.3.2",
    "typescript": "^5.4.5"
  },
  "volta": {
    "node": "24.14.1"
  },
  "workspaces": [
    "ui"
  ]
}
